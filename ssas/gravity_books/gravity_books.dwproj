  <Configurations>
    <Configuration>
      <Name>Development</Name>
      <Options>
        <ConnectionMappings>
          <ConfigurationSetting>
            <Id>gravity_dwh_src</Id>
            <Name>gravity_dwh_src</Name>
            <Value xsi:type="xsd:string">Provider=MSOLEDBSQL.1;Integrated Security=SSPI;Initial Catalog=gravity_books_DWH</Value>
          </ConfigurationSetting>
        </ConnectionMappings>
        <ConnectionSecurityMappings>
          <ConfigurationSetting>
            <Id>gravity_dwh_src</Id>

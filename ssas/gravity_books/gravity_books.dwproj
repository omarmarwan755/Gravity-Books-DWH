      <FullPath>c2.cube</FullPath>
      <Dependencies>
        <ProjectItem>
          <Name>c2.partitions</Name>
          <FullPath>c2.partitions</FullPath>
        </ProjectItem>
      </Dependencies>
    </ProjectItem>
  </Cubes>
